---
import '../styles/global.css';
import {
  profile,
  skills,
  experience,
  keyProjects,
  certifications,
  education,
  languages,
} from '../data/resume';
import verifiedCerts from '../data/certifications.json';

const skillGroups = Object.entries(skills);
const allCertNames = [...verifiedCerts.map((c) => c.title), ...certifications];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{profile.name} — Resume</title>
  </head>
  <body class="mx-auto max-w-[210mm] bg-white px-10 py-8 font-sans text-[10.5px] leading-snug text-slate-800 print:px-0 print:py-0">
    <header class="border-b-2 border-slate-900 pb-3">
      <h1 class="text-[22px] font-bold tracking-tight text-slate-900">{profile.name}</h1>
      <p class="mt-0.5 text-[13px] font-medium text-cyan-700">{profile.title}</p>
      <p class="mt-2 flex flex-wrap gap-x-3 gap-y-0.5 text-[9.5px] text-slate-600">
        <span>{profile.location}</span>
        <span>&middot;</span>
        <span>{profile.phone}</span>
        <span>&middot;</span>
        <span>{profile.email}</span>
        <span>&middot;</span>
        <span>{profile.linkedin.replace('https://', '')}</span>
        <span>&middot;</span>
        <span>{profile.github.replace('https://', '')}</span>
      </p>
    </header>

    <section class="mt-3">
      <p class="text-[10.5px] leading-relaxed text-slate-700">{profile.summary}</p>
    </section>

    <section class="mt-4">
      <h2 class="text-[11px] font-bold uppercase tracking-wide text-slate-900">Technical Skills</h2>
      <div class="mt-1.5 grid grid-cols-2 gap-x-6 gap-y-0.5 border-t border-slate-200 pt-1.5">
        {skillGroups.map(([group, items]) => (
          <p class="text-[9.5px] leading-relaxed">
            <span class="font-semibold text-slate-900">{group}:</span>{' '}
            <span class="text-slate-600">{items.join(', ')}</span>
          </p>
        ))}
      </div>
    </section>

    <section class="mt-4">
      <h2 class="text-[11px] font-bold uppercase tracking-wide text-slate-900">Experience</h2>
      <div class="mt-1.5 border-t border-slate-200 pt-1.5">
        {experience.map((job) => (
          <div>
            <div class="flex items-baseline justify-between">
              <p class="text-[11px] font-semibold text-slate-900">{job.role} &mdash; {job.company}</p>
              <p class="text-[9.5px] font-medium text-slate-500">{job.period}</p>
            </div>
            <ul class="mt-1 list-disc space-y-0.5 pl-4 text-[9.5px] text-slate-700">
              {job.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-4">
      <h2 class="text-[11px] font-bold uppercase tracking-wide text-slate-900">Key Projects</h2>
      <div class="mt-1.5 grid grid-cols-2 gap-x-6 gap-y-1 border-t border-slate-200 pt-1.5">
        {keyProjects.map((kp) => (
          <p class="text-[9.5px] leading-relaxed">
            <span class="font-semibold text-slate-900">{kp.name}:</span>{' '}
            <span class="text-slate-600">{kp.description}</span>
          </p>
        ))}
      </div>
    </section>

    <div class="mt-4 grid grid-cols-2 gap-x-6">
      <section>
        <h2 class="text-[11px] font-bold uppercase tracking-wide text-slate-900">Certifications</h2>
        <ul class="mt-1.5 list-disc space-y-0.5 border-t border-slate-200 pl-4 pt-1.5 text-[9.5px] text-slate-700">
          {allCertNames.map((cert) => (
            <li>{cert}</li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="text-[11px] font-bold uppercase tracking-wide text-slate-900">Education</h2>
        <div class="mt-1.5 border-t border-slate-200 pt-1.5 text-[9.5px]">
          <p class="font-semibold text-slate-900">{education.degree}</p>
          <p class="text-slate-600">{education.school} &middot; {education.period} &middot; {education.gpa}</p>
        </div>

        <h2 class="mt-3 text-[11px] font-bold uppercase tracking-wide text-slate-900">Languages</h2>
        <p class="mt-1.5 border-t border-slate-200 pt-1.5 text-[9.5px] text-slate-700">
          {languages.map((l) => `${l.name} (${l.level})`).join(' · ')}
        </p>
      </section>
    </div>
  </body>
</html>
