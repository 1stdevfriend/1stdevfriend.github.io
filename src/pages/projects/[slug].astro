---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const description =
  `${data.title} — ${data.category}. ` +
  (data.tags.length ? `Built with ${data.tags.slice(0, 5).join(', ')}.` : '');
---

<BaseLayout title={data.title} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <a href="/projects/" class="text-sm font-medium text-cyan-600 hover:underline dark:text-cyan-400">
      &larr; All projects
    </a>

    <div class="mt-6 flex flex-wrap items-start justify-between gap-3">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">{data.title}</h1>
      {data.featured && (
        <span class="rounded-full bg-cyan-600 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white dark:bg-cyan-500 dark:text-slate-950">
          Featured
        </span>
      )}
    </div>

    <p class="mt-2 font-mono text-sm uppercase tracking-wide text-slate-400 dark:text-slate-500">
      {data.category}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {data.tags.map((tag: string) => (
        <span class="rounded-md bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
          {tag}
        </span>
      ))}
    </div>

    <div class="prose prose-slate mt-10 max-w-none leading-relaxed text-slate-700 dark:prose-invert dark:text-slate-300">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">My Role</h2>
      <Content />
    </div>

    {data.notes && (
      <div class="mt-8 rounded-lg border border-slate-200 bg-slate-50 p-4 text-sm text-slate-500 dark:border-slate-800 dark:bg-slate-900/50 dark:text-slate-400">
        <strong class="font-semibold text-slate-600 dark:text-slate-300">Note:</strong> {data.notes}
      </div>
    )}

    <div class="mt-10 border-t border-slate-200 pt-6 dark:border-slate-800">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-400 dark:text-slate-500">
        Repositories
      </h2>
      <ul class="mt-3 space-y-1 font-mono text-sm text-slate-500 dark:text-slate-400">
        {data.repos.map((repo: string) => (
          <li>{repo}</li>
        ))}
      </ul>
    </div>
  </article>
</BaseLayout>
