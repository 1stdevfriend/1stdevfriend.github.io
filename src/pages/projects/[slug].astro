---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { data } = project;
const { Content } = await render(project);

const description =
  `${data.title} — ${data.category}. ` +
  (data.tags.length ? `Built with ${data.tags.slice(0, 5).join(', ')}.` : '');
---

<BaseLayout title={data.title} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    <a href="/projects/" class="text-sm font-medium text-cyan-600 hover:underline dark:text-cyan-400">
      &larr; All projects
    </a>

    <div class="mt-6 flex items-start gap-4">
      {data.logo && (
        <img
          src={data.logo}
          alt=""
          width="56"
          height="56"
          class="h-14 w-14 shrink-0 rounded-xl border border-slate-100 bg-white object-contain p-1.5 dark:border-slate-800"
        />
      )}
      <div class="flex flex-1 flex-wrap items-start justify-between gap-3">
        <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100">{data.title}</h1>
        {data.featured && (
          <span class="rounded-full bg-cyan-600 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white dark:bg-cyan-500 dark:text-slate-950">
            Featured
          </span>
        )}
      </div>
    </div>

    <p class="mt-2 font-mono text-sm uppercase tracking-wide text-slate-400 dark:text-slate-500">
      {data.category}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {data.tags.map((tag: string) => (
        <span class="rounded-md bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-300">
          {tag}
        </span>
      ))}
    </div>

    {data.liveUrl && (
      <a
        href={data.liveUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-6 inline-flex items-center gap-1.5 rounded-md bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-cyan-600 dark:bg-cyan-500 dark:text-slate-950 dark:hover:bg-cyan-400"
      >
        Visit Live Site
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V13.5m-9 3L20.25 3m0 0h-5.25m5.25 0v5.25" />
        </svg>
      </a>
    )}

    <div class="prose prose-slate mt-10 max-w-none leading-relaxed text-slate-700 dark:prose-invert dark:text-slate-300">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-slate-100">My Role</h2>
      <Content />
    </div>
  </article>
</BaseLayout>
