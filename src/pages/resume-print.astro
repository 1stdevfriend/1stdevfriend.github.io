---
import '../styles/global.css';
import {
  profile,
  skills,
  experience,
  keyProjects,
  certifications,
  education,
  languages,
} from '../data/resume';
import verifiedCerts from '../data/certifications.json';

const skillGroups = Object.entries(skills);
const allCertNames = [...verifiedCerts.map((c) => c.title), ...certifications];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{profile.name} — Resume</title>
  </head>
  <body class="mx-auto max-w-[210mm] bg-white px-10 py-8 font-sans text-[10.5px] leading-snug text-slate-800 print:px-0 print:py-0">
    <header class="border-b-2 border-slate-900 pb-3 text-center">
      <h1 class="text-[24px] font-bold tracking-tight text-slate-900">{profile.name}</h1>
      <p class="mt-1 text-[14px] font-semibold text-slate-800">{profile.title}</p>
      <p class="mt-2 text-[10px] text-slate-600">
        {profile.location} <span class="mx-1.5">|</span> {profile.phone} <span class="mx-1.5">|</span> {profile.email}
      </p>
      <p class="mt-0.5 text-[10px] text-slate-600">
        {profile.linkedin.replace('https://', '')} <span class="mx-1.5">|</span> {profile.github.replace('https://', '')}
      </p>
    </header>

    <div class="mt-4 border-l-4 border-cyan-600 bg-slate-50 px-4 py-2.5 text-[10px] leading-relaxed text-slate-700">
      <span class="font-semibold text-slate-900">Relocation:</span> {profile.relocation}
    </div>

    <section class="mt-5">
      <h2 class="border-b border-slate-300 pb-1 text-[12px] font-bold uppercase tracking-wide text-slate-900">
        Professional Summary
      </h2>
      <p class="mt-2 text-[10.5px] leading-relaxed text-slate-700">{profile.summary}</p>
    </section>

    <section class="mt-5">
      <h2 class="border-b border-slate-300 pb-1 text-[12px] font-bold uppercase tracking-wide text-slate-900">
        Technical Skills
      </h2>
      <div class="mt-2 space-y-1">
        {skillGroups.map(([group, items]) => (
          <p class="text-[10px] leading-relaxed">
            <span class="font-semibold text-slate-900">{group}:</span>{' '}
            <span class="text-slate-700">{items.join(', ')}</span>
          </p>
        ))}
      </div>
    </section>

    <section class="mt-5">
      <h2 class="border-b border-slate-300 pb-1 text-[12px] font-bold uppercase tracking-wide text-slate-900">
        Experience
      </h2>
      <div class="mt-2 space-y-3">
        {experience.map((job) => (
          <div>
            <p class="text-[11px] font-semibold text-slate-900">
              {job.role} &mdash; {job.company} ({job.period})
            </p>
            <ul class="mt-1 list-disc space-y-0.5 pl-4 text-[10px] text-slate-700">
              {job.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-5">
      <h2 class="border-b border-slate-300 pb-1 text-[12px] font-bold uppercase tracking-wide text-slate-900">
        Key Projects
      </h2>
      <ul class="mt-2 list-disc space-y-1 pl-4 text-[10px] leading-relaxed text-slate-700">
        {keyProjects.map((kp) => (
          <li>
            <span class="font-semibold text-slate-900">{kp.name}:</span> {kp.description}
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-5">
      <h2 class="border-b border-slate-300 pb-1 text-[12px] font-bold uppercase tracking-wide text-slate-900">
        Certifications
      </h2>
      <p class="mt-2 text-[10px] leading-relaxed text-slate-700">{allCertNames.join(' • ')}</p>
    </section>

    <section class="mt-5">
      <h2 class="border-b border-slate-300 pb-1 text-[12px] font-bold uppercase tracking-wide text-slate-900">
        Education
      </h2>
      <p class="mt-2 text-[10.5px] text-slate-700">
        <span class="font-semibold text-slate-900">{education.degree}</span><br />
        {education.school} &middot; {education.period} &middot; {education.gpa}
      </p>
    </section>

    <section class="mb-8 mt-5">
      <h2 class="border-b border-slate-300 pb-1 text-[12px] font-bold uppercase tracking-wide text-slate-900">
        Languages
      </h2>
      <p class="mt-2 text-[10px] text-slate-700">
        {languages.map((l) => `${l.name} (${l.level})`).join(' · ')}
      </p>
    </section>
  </body>
</html>
