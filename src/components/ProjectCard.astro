---
interface Props {
  slug: string;
  title: string;
  category: string;
  tags: string[];
  complexity: string;
  featured?: boolean;
  logo?: string;
  liveUrl?: string;
}

const { slug, title, category, tags, complexity, featured = false, logo, liveUrl } = Astro.props;
const visibleTags = tags.slice(0, 6);
const extraCount = tags.length - visibleTags.length;
const initial = title.trim().charAt(0).toUpperCase();
---

<a
  href={`/projects/${slug}/`}
  class={`group flex h-full flex-col rounded-xl border p-5 transition-all hover:-translate-y-0.5 hover:shadow-lg ${
    featured
      ? 'border-cyan-300 bg-cyan-50/40 hover:shadow-cyan-100 dark:border-cyan-800 dark:bg-cyan-950/20 dark:hover:shadow-cyan-950'
      : 'border-slate-200 bg-white hover:shadow-slate-100 dark:border-slate-800 dark:bg-slate-900 dark:hover:shadow-none'
  }`}
>
  <div class="mb-2 flex items-start gap-3">
    {logo ? (
      <img
        src={logo}
        alt=""
        width="36"
        height="36"
        loading="lazy"
        class="h-9 w-9 shrink-0 rounded-lg border border-slate-100 bg-white object-contain p-1 dark:border-slate-800"
      />
    ) : (
      <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-slate-100 font-mono text-sm font-semibold text-slate-400 dark:bg-slate-800 dark:text-slate-500">
        {initial}
      </div>
    )}
    <div class="min-w-0 flex-1">
      <div class="flex items-start justify-between gap-2">
        <h3 class="font-semibold leading-snug text-slate-900 group-hover:text-cyan-700 dark:text-slate-100 dark:group-hover:text-cyan-400">
          {title}
        </h3>
        <div class="flex shrink-0 items-center gap-1.5">
          {liveUrl && (
            <span
              class="flex items-center gap-1 rounded-full bg-emerald-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-400"
              title="Live site available"
            >
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-500" aria-hidden="true"></span>
              Live
            </span>
          )}
          {featured && (
            <span class="rounded-full bg-cyan-600 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-white dark:bg-cyan-500 dark:text-slate-950">
              Featured
            </span>
          )}
        </div>
      </div>
    </div>
  </div>

  <div class="mb-3 flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-slate-400 dark:text-slate-500">
    <span>{category}</span>
    {complexity && complexity !== 'Unknown' && (
      <>
        <span aria-hidden="true">&middot;</span>
        <span>{complexity}</span>
      </>
    )}
  </div>

  <div class="mt-auto flex flex-wrap gap-1.5 pt-2">
    {visibleTags.map((tag) => (
      <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs text-slate-600 dark:bg-slate-800 dark:text-slate-300">
        {tag}
      </span>
    ))}
    {extraCount > 0 && (
      <span class="rounded-md px-2 py-0.5 text-xs text-slate-400 dark:text-slate-500">+{extraCount}</span>
    )}
  </div>
</a>
